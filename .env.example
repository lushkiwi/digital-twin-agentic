# ---- Eclipse Ditto ----
DITTO_BASE_URL=http://localhost:8080
DITTO_USER=ditto
DITTO_PASS=ditto
DITTO_VERSION=3.5.12
DITTO_EXTERNAL_PORT=8080
THING_NS=org.acme

# ---- LLM (BYO subscription; UI Settings can override at runtime) ----
# LiteLLM model string: provider/model
#   openrouter/anthropic/claude-sonnet-5 | anthropic/claude-fable-5 | openai/gpt-5.6 | ollama/llama3.1
LLM_MODEL=openrouter/anthropic/claude-sonnet-5
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ---- Services ----
BACKEND_PORT=8000
SIM_DEBUG_PORT=9001

# ---- Tuning ----
TELEMETRY_INTERVAL_S=1.0
SLEEPER_REFLECT_INTERVAL_S=60
MAX_TOOL_ITERATIONS=8
